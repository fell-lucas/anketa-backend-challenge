{
  "name": "pollpapa-core",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm db:generate:client && nest build",
    "prisma:prod": "prisma migrate deploy",
    "prisma:seed": "[ \"$RAILWAY_ENVIRONMENT_NAME\" = \"staging\" ] || [ \"$RAILWAY_ENVIRONMENT_NAME\" = \"integration\" ] ] && prisma db seed",
    "prisma:seed:production": "npx ts-node ./prisma/productionSeeds.ts",
    "prisma:seed:dynamic": "npx ts-node ./prisma/dynamicSeeds.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "npm run start:dev",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:integration": "prisma generate --generator client && prisma migrate reset --skip-generate -f && node dist/apps/core/src/main",
    "start:prod": "prisma generate --generator client && prisma migrate deploy && npx ts-node ./prisma/dynamicSeeds.ts && node dist/apps/core/src/main",
    "start:prod:reset": "prisma generate --generator client && prisma migrate reset --skip-generate --force --skip-seed && npx ts-node ./prisma/productionSeeds.ts && node dist/apps/core/src/main",
    "start:prod:old": "prisma generate --generator client && prisma migrate deploy && node dist/apps/core/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --testRegex \".e2e-spec.ts$\"",
    "test:ci": "NODE_OPTIONS='--max-old-space-size=6144' jest --testRegex \".e2e-spec.ts$\" --coverage=false --logHeapUsage",
    "test:watch": "jest --watch",
    "test:cov": "jest --testPathIgnorePatterns=\"^.*admin.*$\" --coverage --verbose",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --testRegex \".e2e-spec.ts$\"",
    "swagger:save": "node dist/apps/core/src/swagger.cli.js",
    "db:generate": "prisma generate",
    "db:generate:client": "prisma generate --generator client",
    "db:start": "docker start -ia pollpapa_postgres || docker run -it --name pollpapa_postgres -p 5432:5432 -e POSTGRES_PASSWORD=changeme -e POSTGRES_USER=pollpapa -e POSTGRES_DB=pollpapa postgres:16-alpine",
    "db:studio": "pnpm prisma studio",
    "db:reset": "pnpm prisma migrate reset --skip-generate -f",
    "s3:dev": "docker run --rm -it -p 4566:4566 -p 4510-4559:4510-4559 localstack/localstack",
    "firebase:login": "ts-node src/libraries/firebase/cli/firebase-login.ts",
    "inngest:dev": "npx inngest-cli@latest dev"
  },
  "dependencies": {
    "@adminjs/express": "^6.1.1",
    "@adminjs/nestjs": "^6.1.0",
    "@adminjs/passwords": "^4.0.0",
    "@adminjs/prisma": "^5.0.4",
    "@adminjs/relations": "^1.1.2",
    "@aws-sdk/client-ses": "^3.911.0",
    "@aws-sdk/client-sns": "^3.716.0",
    "@babel/plugin-syntax-import-assertions": "^7.24.7",
    "@faker-js/faker": "^9.4.0",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/microservices": "^10.3.8",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.3.3",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/websockets": "^10.3.3",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "6.11.0",
    "@repo/contracts": "workspace:*",
    "@repo/system": "workspace:*",
    "adminjs": "^7.8.16",
    "aws-sdk": "^2.1677.0",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "buffer-to-stream": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.5.1",
    "csv-parse": "^5.6.0",
    "dd-trace": "^5.73.0",
    "dotenv": "^16.4.7",
    "fast-folder-size": "^2.2.0",
    "firebase": "^11.0.2",
    "firebase-admin": "^13.0.1",
    "glob": "^10.3.12",
    "google-auth-library": "^9.15.0",
    "inngest": "^3.35.1",
    "lodash": "^4.17.21",
    "md5": "^2.3.0",
    "ms": "^2.1.3",
    "multer": "1.4.5-lts.1",
    "nest-inngest": "^1.3.2",
    "nestjs-pino": "^4.0.0",
    "passport": "^0.7.0",
    "passport-http": "^0.3.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino-http": "^11.0.0",
    "pino-rotating-file-stream": "^0.0.2",
    "prisma-class-generator": "^0.2.11",
    "reflect-metadata": "^0.2.0",
    "remove": "^0.1.5",
    "rotating-file-stream": "^3.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "stream-chat": "^8.59.0",
    "tar": "^6.2.1",
    "verify-apple-id-token": "^3.1.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@testcontainers/postgresql": "^11.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/lodash": "^4.14.202",
    "@types/md5": "^2.3.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "pino-pretty": "^10.3.1",
    "pkg": "^5.8.1",
    "prettier": "^3.0.0",
    "prettier-2": "npm:prettier@^2",
    "prisma": "^6.11.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\..*spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.{t,j}s",
      "!**/*.dto.ts",
      "!**/admin/**/*.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "prettierPath": "prettier-2",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  },
  "prisma": {
    "seed": "npx ts-node ./prisma/seeds.ts",
    "schema": "./prisma"
  }
}
