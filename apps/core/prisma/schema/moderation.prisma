// ===== ENUMS =====

enum ReportType {
  flagAsSensitive
  spam
  nudity
  minorSafety
  bullyingAndHarassment
  violentAndGraphicContent
  illegalActivities
  hateSpeech
  falseInformation
  suicideEatingDisorderSelfHarm
  others
}

enum ReportedSubjectType {
  USER
  POST
  COMMENT
}

enum ReportedSubjectModerationStatus {
  PENDING_REVIEW
  PENDING_APPEAL
  ESCALATED
  UNDER_REVIEW
  RESOLVED
}

enum ModerationActionType {
  ESCALATE
  MARK_AS_SENSITIVE
  MARK_AS_NOT_SENSITIVE
  DISMISS
  SUSPEND_REPORTED_SUBJECT
  SUSPEND_USER
  UNSUSPEND_REPORTED_SUBJECT
  UNSUSPEND_USER
  REOPEN
}

enum ModerationSuspensionLevel {
  WARNING
  TEMPORARY_1_DAY
  TEMPORARY_2_DAYS
  TEMPORARY_7_DAYS
  PERMANENT
  CUSTOM
}

// ===== MODELS =====

model ReportedSubject {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  type             ReportedSubjectType
  moderationStatus ReportedSubjectModerationStatus @map("moderation_status")

  moderationStatusChangedAt DateTime? @map("moderation_status_changed_at")

  userId    String? @map("user_id") @db.Uuid
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  postId    String? @map("post_id") @db.Uuid
  post      Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)

  commentId String?  @map("comment_id") @db.Uuid
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  activeModerationId String?                    @unique @map("active_moderation_id") @db.Uuid
  activeModeration   ReportedSubjectModeration? @relation("ActiveModeration", fields: [activeModerationId], references: [id], onDelete: SetNull)

  latestModerationActionId String?           @unique @map("latest_moderation_action_id") @db.Uuid
  latestModerationAction   ModerationAction? @relation("LatestModerationAction", fields: [latestModerationActionId], references: [id], onDelete: SetNull)

  reportsCount Int @default(0) @map("reports_count")

  reports           Report[]
  moderations       ReportedSubjectModeration[] @relation("SubjectModerations")
  moderationActions ModerationAction[]          @relation("SubjectActions")

  @@map("reported_subject")
}

model Report {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  type            ReportType
  message         String?
  hasBeenReviewed Boolean @default(false) @map("has_been_reviewed")

  reportedSubjectId String          @map("reported_subject_id") @db.Uuid
  reportedSubject   ReportedSubject @relation(fields: [reportedSubjectId], references: [id])

  userId String? @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  adminId String? @map("admin_id") @db.Uuid
  admin   Admin?  @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([reportedSubjectId])
  @@map("reports")
}

model ReportedSubjectModeration {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  reportedSubjectId String          @map("reported_subject_id") @db.Uuid
  reportedSubject   ReportedSubject @relation("SubjectModerations", fields: [reportedSubjectId], references: [id], onDelete: Cascade)

  moderatorId String @map("moderator_id") @db.Uuid
  moderator   Admin  @relation(fields: [moderatorId], references: [id], onDelete: Cascade)

  moderationActions ModerationAction[]

  activeForReportedSubject ReportedSubject? @relation("ActiveModeration")

  @@unique([reportedSubjectId, moderatorId])
  @@map("reported_subject_moderation")
}

model ModerationAction {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  type   ModerationActionType
  reason String?
  isEdit Boolean @default(false) @map("is_edit")

  reportedSubjectId String          @map("reported_subject_id") @db.Uuid
  reportedSubject   ReportedSubject @relation("SubjectActions", fields: [reportedSubjectId], references: [id], onDelete: Cascade)

  moderationId String                    @map("moderation_id") @db.Uuid
  moderation   ReportedSubjectModeration @relation(fields: [moderationId], references: [id], onDelete: Cascade)

  violationCategory    String?                    @map("violation_category")
  violationSubcategory String?                    @map("violation_subcategory")
  suspensionLevel      ModerationSuspensionLevel? @map("suspension_level")
  notes                String?

  suspensionStartsAt DateTime? @map("suspension_starts_at")
  suspensionEndsAt   DateTime? @map("suspension_ends_at")

  latestForReportedSubject ReportedSubject? @relation("LatestModerationAction")

  @@map("moderation_action")
}
